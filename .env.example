# DeckTerm runtime example for a dedicated server.
#
# For public access, keep DeckTerm bound to localhost and expose it through
# Cloudflare Tunnel or a reverse proxy. Use HOST=0.0.0.0 only for a trusted LAN
# or a private dev VM.

PORT=4174
HOST=127.0.0.1
# Choose one:
#   cloudflare-tunnel  - tunnel only; access enforcement happens at the
#                        Cloudflare edge (Application policies). Server-side
#                        JWT validation is OFF.
#   cloudflare-access  - tunnel + DeckTerm validates the Cf-Access JWT itself
#                        (requires CF_ACCESS_TEAM_NAME and CF_ACCESS_AUD).
#   nginx | local | direct - other deployment shapes.
DECKTERM_PUBLISH_MODE=cloudflare-tunnel

TMUX_BACKEND=1
TMUX_SESSION_NAMESPACE=deckterm

OPENCODE_WEB_DEBUG=0
OPENCODE_WEB_MAX_TERMINALS=10
MAX_TERMINALS_PER_USER=10
TERMINAL_IDLE_TIMEOUT_MS=7200000
SCROLLBACK_MAX_LINES=2000
SCROLLBACK_MAX_BYTES=1048576
DECKTERM_STATE_DIR=/home/deploy/.deckterm
DECKTERM_TASK_MAX_ROUNDS=5
DECKTERM_TASK_PROVIDERS=codex,claude

# Restrict file and git APIs to these roots.
ALLOWED_FILE_ROOTS=/home/deploy

# Required only for DECKTERM_PUBLISH_MODE=cloudflare-access (or legacy
# DECKTERM_PUBLISH_MODE=cloudflare). For cloudflare-tunnel keep =0 and rely
# on Cloudflare Access policies at the edge.
CF_ACCESS_REQUIRED=0
# Fill these only when CF_ACCESS_REQUIRED=1.
# CF_ACCESS_TEAM_NAME=your-team-name
# CF_ACCESS_AUD=your-cloudflare-access-application-aud
TRUSTED_ORIGINS=https://deckterm.example.com
