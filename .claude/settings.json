{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/doc-commit-reminder.sh",
            "if": "Bash(git commit*)",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
