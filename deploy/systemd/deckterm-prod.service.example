[Unit]
Description=DeckTerm production service
After=network.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/home/deploy/apps/deckterm/prod/current
EnvironmentFile=/home/deploy/apps/deckterm/shared/prod.env
ExecStart=/home/deploy/.bun/bin/bun run start
Restart=always
RestartSec=3
KillSignal=SIGTERM
TimeoutStopSec=10
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
